<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Learning.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:Learning"
       Title="Learning">

    <ShellContent
        FlyoutItemIsVisible="False"
        Shell.NavBarIsVisible="False"
        Shell.TabBarIsVisible="False"      
        ContentTemplate="{DataTemplate local:Login}"
        Route="Login" />
    
    <ShellContent
        FlyoutItemIsVisible="False"
        Shell.TabBarIsVisible="False"      
        ContentTemplate="{DataTemplate local:TeamForm}"
        Route="TeamForm" />

    <FlyoutItem FlyoutDisplayOptions="AsMultipleItems"
        >
        <ShellContent
            Title="Main Menu"
            Shell.NavBarIsVisible="True"
            Shell.TabBarIsVisible="False"
            ContentTemplate="{DataTemplate local:MainPage}"
            Route="MainPage" />

        <ShellContent
    Title="Create Form"
            Shell.TabBarIsVisible="False"
            ContentTemplate="{DataTemplate local:Pages.CreateFormPage}"
            Route="CreateFormPage" />

        <ShellContent
    Title="Do Forms"
            Shell.TabBarIsVisible="False"
            ContentTemplate="{DataTemplate local:Pages.Forms}"
            Route="Forms" />

        <ShellContent
    Title="View Submissions"
            Shell.TabBarIsVisible="False"
            ContentTemplate="{DataTemplate local:Pages.FormDataPage}"
            Route="FormDataPage" />

    </FlyoutItem>


    <MenuFlyoutItem
        Text="Logout"
        Clicked="OnLogoutClicked" />


</Shell>